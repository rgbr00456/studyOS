{
  "rewrites": [
    {
      "source": "/app/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    }
  ],
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/$",
      "dest": "/landing.html"
    },
    {
      "src": "^/landing\\.html$",
      "dest": "/landing.html"
    }
  ]
}